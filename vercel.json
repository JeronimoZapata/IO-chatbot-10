{
    "builds": [
        {
            "src": "frontend/package.json",
            "use": "@vercel/next"
        },
        {
            "src": "backend/src/vercel-handler.ts",
            "use": "@vercel/node",
            "config": {
                "maxDuration": 30
            }
        }
    ],
    "routes": [
        {
            "src": "/_/backend/(.*)",
            "dest": "backend/src/vercel-handler.ts"
        }
    ]
}
